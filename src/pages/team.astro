---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { TeamGrid } from '../components/TeamGrid';
---

<Layout title="Our Team | Smart Cushion">
	<Navbar client:load />
	<main class="h-screen bg-black overflow-hidden flex flex-col justify-center pt-20">
		<section class="container mx-auto px-4">
			<div class="text-center mb-8">
				<h1 class="text-3xl lg:text-5xl font-bold mb-3 text-white tracking-tight">
					The Minds Behind <br/><span class="text-primary italic">Smart Cushion</span>
				</h1>
				<p class="text-lg text-neutral-400 max-w-2xl mx-auto leading-relaxed">
					Meet the innovators dedicated to revolutionizing ergonomic health through AI and IoT technology.
				</p>
			</div>

			<TeamGrid client:load />
		</section>
	</main>
</Layout>
