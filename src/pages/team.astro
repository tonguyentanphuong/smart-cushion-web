---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { TeamGrid } from '../components/TeamGrid';
---

<Layout title="Our Team | Smart Cushion">
	<Navbar client:load />
	<main class="h-screen bg-black overflow-hidden flex flex-col justify-center pt-20">
		<section class="container mx-auto px-4 relative">
			{/* Background Ambient Effect for Header */}
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-4xl h-40 -z-10 bg-primary/10 blur-[100px] rounded-full animate-pulse"></div>

			<div class="text-center mb-10 animate-fade-in-down relative z-10">
				<h1 class="text-3xl lg:text-6xl font-bold mb-4 text-white tracking-tight">
					The Minds Behind <br/>
					<span class="text-primary italic">Smart Cushion</span>
				</h1>
				<p class="text-lg lg:text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed">
					Meet the innovators dedicated to revolutionizing ergonomic health through <span class="text-white font-medium">AI and IoT technology.</span>
				</p>
			</div>

			<TeamGrid client:load />
		</section>
	</main>
</Layout>

<style>
	@keyframes fade-in-down {
		0% { opacity: 0; transform: translateY(-20px); }
		100% { opacity: 1; transform: translateY(0); }
	}
	.animate-fade-in-down {
		animation: fade-in-down 1s ease-out forwards;
	}
	@keyframes gradient-x {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	.animate-gradient-x {
		animation: gradient-x 5s ease infinite;
	}
</style>
