---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { ArchitectureLayers } from '../components/ArchitectureLayers';
import { ArchitectureDiagram } from '../components/ArchitectureDiagram';
---

<Layout title="Smart Cushion | System Architecture">
	<Navbar client:load />
	
	<main class="relative overflow-hidden pt-20">
		
		{/* Phân tích 3 mô hình tiêu chuẩn 3-5-7 */}
		<ArchitectureLayers client:load />

		{/* Luồng Dữ liệu thực tế của Smart Cushion (Từ Edge lên Cloud) */}
		<ArchitectureDiagram client:load />
		
	</main>

	<footer class="py-12 border-t bg-black/50">
		<div class="container mx-auto px-4">
			<div class="flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="flex items-center gap-2 font-bold text-xl">
					<div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-white text-xs">S</div>
					<span>SmartCushion Architecture</span>
				</div>
				
				<div class="flex gap-8 text-sm font-medium text-muted-foreground">
					<a href="/" class="hover:text-primary">Back to Home</a>
				</div>
				
				<p class="text-sm text-muted-foreground">
					© 2026 SmartCushion Inc.
				</p>
			</div>
		</div>
	</footer>
</Layout>
