---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar';
import { motion } from 'framer-motion';
import { Mail, MapPin, Globe, Award, MessageSquare } from 'lucide-react';
---

<Layout title="Contact Us | Smart Cushion Project">
	<Navbar client:load />
	<main class="min-h-screen bg-black pt-32 pb-20 relative overflow-hidden">
		{/* Background Decor */}
		<div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10">
			<div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/10 blur-[120px] rounded-full animate-pulse"></div>
			<div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-500/10 blur-[120px] rounded-full animate-pulse" style="animation-delay: 2s;"></div>
		</div>

		<div class="container mx-auto px-4 relative z-10">
			<div class="max-w-5xl mx-auto">
				<div class="text-center mb-16">
					<span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-mono uppercase tracking-widest mb-4">
						<Award size={14} /> NTUST Final Project
					</span>
					<h1 class="text-4xl lg:text-7xl font-bold text-white mb-6 tracking-tight">
						Get in Touch with <br/><span class="text-primary italic">Our Team.</span>
					</h1>
					<p class="text-xl text-neutral-400 max-w-2xl mx-auto leading-relaxed">
						Have questions about our Cloud-Fog architecture or AI implementation? Reach out to the researchers behind Smart Cushion.
					</p>
				</div>

				<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
					{/* Contact Cards */}
					<div class="lg:col-span-1 space-y-6">
						<div class="p-8 rounded-[2rem] bg-neutral-900/50 border border-neutral-800 backdrop-blur-xl">
							<div class="w-12 h-12 rounded-2xl bg-primary/20 flex items-center justify-center text-primary mb-6">
								<MapPin size={24} />
							</div>
							<h3 class="text-xl font-bold text-white mb-2">Location</h3>
							<p class="text-neutral-400 text-sm leading-relaxed">
								National Taiwan University of Science and Technology (NTUST)<br/>
								No. 43, Keelung Rd, Sec. 4, Da'an Dist, Taipei City, Taiwan.
							</p>
						</div>

						<div class="p-8 rounded-[2rem] bg-neutral-900/50 border border-neutral-800 backdrop-blur-xl">
							<div class="w-12 h-12 rounded-2xl bg-blue-500/20 flex items-center justify-center text-blue-400 mb-6">
								<Globe size={24} />
							</div>
							<h3 class="text-xl font-bold text-white mb-2">Course Info</h3>
							<p class="text-neutral-400 text-sm leading-relaxed">
								Course: Cloud Fog Computing<br/>
								Semester: 114-2<br/>
								Category: Smart IoT Solution
							</p>
						</div>
					</div>

					{/* Contact Form / Info List */}
					<div class="lg:col-span-2 p-10 rounded-[2.5rem] bg-white/[0.03] border border-white/10 backdrop-blur-2xl">
						<div class="flex items-center gap-4 mb-10">
							<div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white">
								<MessageSquare size={20} />
							</div>
							<h2 class="text-2xl font-bold text-white">Project Inquiry</h2>
						</div>

						<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
							<div class="space-y-4">
								<label class="text-xs font-mono text-neutral-500 uppercase tracking-widest">General Email</label>
								<div class="flex items-center gap-3 p-4 rounded-2xl bg-black border border-neutral-800 text-white">
									<Mail size={18} className="text-primary" />
									<span class="text-xs sm:text-sm font-medium">114cloudfog_team5_smartcushion@gmail.com</span>
								</div>
							</div>
							<div class="space-y-4">
								<label class="text-xs font-mono text-neutral-500 uppercase tracking-widest">Lab Location</label>
								<div class="flex items-center gap-3 p-4 rounded-2xl bg-black border border-neutral-800 text-white">
									<MapPin size={18} className="text-primary" />
									<span class="text-xs sm:text-sm font-medium">C217, 2F, Gen. Edu. Bldg, TaiwanTech Hwa Hsia Campus</span>
								</div>
							</div>
						</div>

						<div class="mt-12 p-8 rounded-3xl bg-primary/5 border border-primary/20">
							<h4 class="text-white font-bold mb-4">Technical Discussion?</h4>
							<p class="text-neutral-400 text-sm mb-6 leading-relaxed">
								We are open to discussing the latency benchmarks and MQTT broker configurations used in our Fog-Node implementation.
							</p>
							<button class="w-full py-4 bg-primary text-white rounded-2xl font-bold hover:scale-[1.02] transition-transform shadow-lg shadow-primary/20">
								Send us a Message
							</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</main>
</Layout>
